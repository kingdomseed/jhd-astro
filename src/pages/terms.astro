          <p>
            Mythic Game Master Emulator 2nd Edition © Word Mill Creative LLC. Used under license. Mythic GME apps © Jason Holt
            Digital LLC. All rights reserved.
          </p>
        </section>

        <section class="legal-section" aria-labelledby="terms-contact">
          <h2 id="terms-contact">15) Contact</h2>
          <p>If you have questions about these Terms, contact:</p>
          <ul>
            <li><strong>Email:</strong> <a href="mailto:legal@jasonholtdigital.com">legal@jasonholtdigital.com</a></li>
            <li><strong>Mail:</strong> Jason Holt Digital LLC, 1111b S Governors Avenue STE 21904, Dover, DE 19904 US</li>
          </ul>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>
