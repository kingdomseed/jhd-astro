---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';
---
<BaseLayout
  title="404 — Page Not Found | Mythic GME Apps"
  description="Sorry, we can't find that page. Try the homepage, Apps, Support, or Contact."
  canonicalPath="/404/"
  mainClass="error-main"
>
  <PageHeader
    title="404 — Page Not Found"
    subtitle="Oops! Something went missing"
    description="The page you're looking for doesn't exist or may have moved. Let's get you back on track."
    accent="Error"
    layout="left"
    icon="fa-solid fa-triangle-exclamation"
    colorScheme="accent"
  />

  <section class="section" aria-labelledby="nf-title">
    <div class="container">
      <header class="section-head" aria-hidden="true">
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">404</span>
      </header>
      <div class="error-card">
        <h1 id="nf-title" class="error-title">Page not found</h1>
        <p class="error-summary">The page you were looking for doesn't exist or may have moved. Choose a destination below.</p>
        <div class="error-actions">
          <a class="btn btn--shadow-primary" href="/">
            <i class="fa-slab fa-regular fa-house" aria-hidden="true"></i>
            Home
          </a>
          <a class="btn btn--shadow-accent" href="/apps">
            <i class="fa-slab fa-regular fa-rocket" aria-hidden="true"></i>
            Apps
          </a>
          <a class="btn btn--shadow-primary" href="/resources">
            <i class="fa-slab fa-regular fa-book-open" aria-hidden="true"></i>
            Resources
          </a>
          <a class="btn btn--shadow-primary" href="/support">
            <i class="fa-slab fa-regular fa-life-ring" aria-hidden="true"></i>
            Support
          </a>
          <a class="btn btn--shadow-primary" href="/blog">
            <i class="fa-slab fa-regular fa-newspaper" aria-hidden="true"></i>
            Blog
          </a>
          <a class="btn btn--shadow-primary" href="/support#contact-panel">
            <i class="fa-slab fa-regular fa-envelope" aria-hidden="true"></i>
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
