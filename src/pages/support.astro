---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';

// Public constants per request (safe to expose client-side)
const FORMSPARK_FORM_ID = 'BrXEDLTap';
const TURNSTILE_SITE_KEY = '0x4AAAAAABhU6Cccio-kREUw';
---
<BaseLayout
  title="Support & Contact | Mythic GME Apps"
  description="Find support, Discord, FAQ, and contact options for Mythic GME Mobile and Mythic GME Digital."
  canonicalPath="/support/"
  alternatePath="/pt/support/"
  mainClass="support-main"
>
  <Fragment slot="head">
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </Fragment>

  <PageHeader
    title="Support & Contact"
    subtitle="Get help, ask questions, or send a message"
    description="Find app support, community help, FAQ answers, and direct contact options in one place."
    accent="Support"
    layout="left"
    icon="fa-solid fa-life-ring"
    visualElement="particles"
    colorScheme="accent"
  />

  <section class="section" aria-labelledby="support-tabs-title">
    <div class="container support-container">
      <header class="section-head" aria-hidden="true">
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">Support</span>
      </header>
      <div class="support-intro">
        <h2 id="support-tabs-title" class="section-title">Find the right help path</h2>
        <p class="support-intro__summary">
          Use Discord for community questions, email for detailed support, or
          browse the FAQ for common answers.
        </p>
      </div>

      <div class="support-tabs" role="presentation">
        <ul class="tab-nav" role="tablist">
          <li>
            <button class="tab-button active" role="tab" aria-selected="true" aria-controls="support-panel" id="support-tab">
              <i class="fa-slab fa-regular fa-life-ring" aria-hidden="true"></i>
              Support &amp; FAQ
            </button>
          </li>
          <li>
            <button class="tab-button" role="tab" aria-selected="false" aria-controls="contact-panel" id="contact-tab">
              <i class="fa-slab fa-regular fa-envelope" aria-hidden="true"></i>
              Contact
            </button>
          </li>
        </ul>
      </div>

      <div id="support-panel" class="tab-content active" role="tabpanel" aria-labelledby="support-tab">

        <section aria-labelledby="help-title">
          <h2 id="help-title">How to Get Help</h2>
          <div class="twoup">
            <div class="panel">
              <h3>Discord</h3>
              <p>Ask questions, share feedback, and talk with other Mythic players.</p>
              <p>
                <a class="btn btn--shadow-discord" href="https://discord.gg/PEDHrhzcnk" target="_blank" rel="noopener">
                  <i class="fa-brands fa-discord" aria-hidden="true"></i>
                  Join Discord
                </a>
              </p>
            </div>
            <div class="panel">
              <h3>Email Support</h3>
              <p>Send detailed issues, account questions, or private support requests by email.</p>
              <p>
                <a class="btn btn--shadow-primary" href="mailto:support@jasonholtdigital.com">
                  <i class="fa-slab fa-regular fa-envelope" aria-hidden="true"></i>
                  Email Support
                </a>
              </p>
            </div>
          </div>
        </section>

        <section id="faqs" aria-labelledby="faqs-title">
          <h2 id="faqs-title">Comprehensive FAQ</h2>

          <!-- General & Platforms Section -->
          <div class="faq-section">
            <button class="faq-section-header" aria-expanded="true" aria-controls="general-section">
              <h3>General & Platforms</h3>
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </button>
            <div id="general-section" class="faq-section-content">

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="what-is-mythic">
                  <strong>What are Mythic GME Mobile and Mythic GME Digital?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="what-is-mythic" class="faq-answer">
                  <p>They are the official Mythic GME 2e apps, built in partnership with Word Mill Creative. They help you answer Fate Questions, roll on Meaning Tables, manage Lists and Scenes, and keep play moving offline.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="who-makes">
                  <strong>Who makes them?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="who-makes" class="faq-answer">
                  <p>The apps are built and maintained by Jason Holt Digital in partnership with Word Mill Creative.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="where-get">
                  <strong>Where can I get them?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="where-get" class="faq-answer">
                  <ul>
                    <li><strong>Apple App Store:</strong> iPhone, iPad, and macOS through Universal Purchase</li>
                    <li><strong>Google Play:</strong> Android phones and tablets</li>
                    <li><strong>Amazon Appstore:</strong> Fire tablets</li>
                    <li><strong>Microsoft Store:</strong> Windows 10 and 11</li>
                    <li><strong>itch.io:</strong> DRM-free desktop downloads for Windows, macOS, and Linux</li>
                    <li><strong>Steam:</strong> planned</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="worldwide">
                  <strong>Are the apps available worldwide?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="worldwide" class="faq-answer">
                  <p>Yes. Availability and pricing vary by store and region.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="cross-platform">
                  <strong>If I purchased the app on one platform, do I need to purchase it on another?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="cross-platform" class="faq-answer">
                  <p>Usually, yes. Most stores handle purchases separately. Apple Universal Purchase covers iPhone, iPad, and macOS, and itch.io includes the supported desktop downloads under one purchase.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="need-book">
                  <strong>Do I need the Mythic GME 2e rulebook?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="need-book" class="faq-answer">
                  <p>The apps are companions to the Mythic GME 2e book. They help you use Mythic during play, but the book teaches the system, examples, variants, and optional rules.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Features & Data Section -->
          <div class="faq-section">
            <button class="faq-section-header" aria-expanded="false" aria-controls="features-section">
              <h3>Features & Data</h3>
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </button>
            <div id="features-section" class="faq-section-content">

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="core-features">
                  <strong>Core features</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="core-features" class="faq-answer">
                  <ul>
                    <li>Fate Chart and Fate Check with Chaos Factor</li>
                    <li>Random Events and Event Focus tables</li>
                    <li>Scene Checks and Scene Adjustments</li>
                    <li>Meaning Tables, including official Mythic GME 2e tables and additional tables from Mythic Magazines and Variations through Expanded Features</li>
                    <li>Lists for Characters, Threads, and Features, including support for Prepared Adventures</li>
                    <li>Scenes with titles, summaries, Chaos Factor, and notes</li>
                    <li>Dice Roller for common dice notation, saved formulas, and custom rolls</li>
                    <li>Journals and the Adventure Log for tracking ongoing play</li>
                    <li>Journal export to JSON and Markdown for backup and sharing</li>
                    <li>iCloud sync for Apple devices, plus custom storage locations on supported non-Apple platforms</li>
                    <li>Expanded Features content from Mythic Magazines and Variations</li>
                    <li>Custom Tables for creating, editing, importing, exporting, tagging, and linking your own oracle tables</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="accessibility">
                  <strong>Accessibility</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="accessibility" class="faq-answer">
                  <ul>
                    <li><strong>Screen reader</strong> support across major platforms.</li>
                    <li><strong>Color-blind</strong> friendly palettes for improved contrast.</li>
                    <li><strong>Large and very-large text</strong> options for key UI.</li>
                    <li><strong>Left-handed mode</strong> for comfortable one-hand use.</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="languages">
                  <strong>Languages</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="languages" class="faq-answer">
                  <p>The apps include the official Brazilian Portuguese localization from RetroPunk Publicações.</p>
                  <p>Italian, French, German, and Spanish include machine-translated localizations for Meaning Tables and Event Focus tables.</p>
                  <p>You can also use Custom Tables to create or adjust your own localized tables, and I hope to support more official localizations over time.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Purchases, Pricing & Upgrades Section -->
          <div class="faq-section">
            <button class="faq-section-header" aria-expanded="false" aria-controls="pricing-section">
              <h3>Purchases, Pricing & Upgrades</h3>
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </button>
            <div id="pricing-section" class="faq-section-content">
              <p><em>Last reviewed: May 27, 2026</em></p>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="new-app">
                  <strong>Why a new app listing?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="new-app" class="faq-answer">
                  <p>The original developer closed their business and stopped work on the legacy app. A few months later I restarted development under Jason Holt Digital. Because the store accounts changed and the codebase was rebuilt, Apple/Google/Amazon treat this as a new product, so it cannot be delivered as a free update to the old listing.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="pricing-store">
                  <strong>Pricing and purchases by store</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="pricing-store" class="faq-answer">
                  <p>Apple, Google Play, and Amazon sell the base app with a one-time Expanded Features unlock. Microsoft Store and itch.io sell Mythic GME Digital as a one-time desktop purchase.</p>
                  <p>Store pages show the current price in your country, including local taxes or regional pricing.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="subscription">
                  <strong>Is this a subscription?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="subscription" class="faq-answer">
                  <p>No. The apps do not use subscriptions. Mobile stores use a one-time Expanded Features unlock, and desktop purchases include the desktop feature set up front.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="expanded-features">
                  <strong>How does the Expanded Features unlock work?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="expanded-features" class="faq-answer">
                  <ul>
                    <li>When you buy the unlock, you keep the Expanded Features available at that time.</li>
                    <li>For the next 12 months, new Expanded Features added to the app are also unlocked for you permanently.</li>
                    <li>After that window, the app still receives fixes and improvements. New Expanded Features may require a new unlock if you decide they are worth adding.</li>
                    <li>Anything you unlock stays unlocked.</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="included-today">
                  <strong>What's included in Expanded Features today?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="included-today" class="faq-answer">
                  <ul>
                    <li>Additional Meaning Tables from Mythic Magazines and Variations.</li>
                    <li>Additional Event Focus tables from Mythic Magazines and Variations.</li>
                    <li>Custom Tables for creating, editing, importing, exporting, tagging, categorizing, and linking your own oracle tables.</li>
                    <li>Hybrid Play.</li>
                    <li>Progress Tracks.</li>
                    <li>Discovery Check.</li>
                    <li>Keyed Scenes.</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="planned-premium">
                  <strong>Expanded Features roadmap</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="planned-premium" class="faq-answer">
                  <p>Roadmap items are subject to change.</p>
                  <ul>
                    <li>Enhanced Note Taking.</li>
                    <li>Character Sheets.</li>
                    <li>NPC Actions.</li>
                    <li>Image Support.</li>
                    <li>Custom Lists.</li>
                  </ul>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="old-app-questions">
                  <strong>Questions about the old app vs this one?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="old-app-questions" class="faq-answer">
                  <p>If you have questions about an original purchase or how it relates to this version, email support@jasonholtdigital.com.</p>
                </div>
              </div>

              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="cross-platform-note">
                  <strong>Cross‑platform note</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="cross-platform-note" class="faq-answer">
                  <p>Purchases usually do not transfer between stores. Apple Universal Purchase covers iPhone, iPad, and macOS. itch.io includes supported desktop downloads under one purchase.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Bug Reporting Section -->
          <div class="faq-section">
            <button class="faq-section-header" aria-expanded="false" aria-controls="support-section">
              <h3>Getting Help</h3>
              <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
            </button>
            <div id="support-section" class="faq-section-content">
              <div class="faq-item">
                <button class="faq-question" aria-expanded="false" aria-controls="report-bug">
                  <strong>How do I report a bug?</strong>
                  <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                </button>
                <div id="report-bug" class="faq-answer">
                  <p>Use in-app feedback from Settings, email Support, or post in the Discord bug reports channel. Include your platform, app version, and what happened.</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <p class="support-note"><small>Check <a href="/blog">Release Notes</a> for recent fixes and known issues.</small></p>
      </div>

      <!-- Contact Tab Content -->
      <div id="contact-panel" class="tab-content" role="tabpanel" aria-labelledby="contact-tab">

        <div class="twoup support-columns">
          <!-- Left column: Contact info -->
          <div>
            <section class="panel" aria-labelledby="contact-info-title">
              <h2 id="contact-info-title">Get in Touch</h2>

              <div class="support-contact-card">
                <h3>Email Contacts</h3>
                <ul>
                  <li><strong>Support:</strong> <a href="mailto:support@jasonholtdigital.com">support@jasonholtdigital.com</a></li>
                  <li><strong>General:</strong> <a href="mailto:jason@jasonholtdigital.com">jason@jasonholtdigital.com</a></li>
                </ul>
              </div>

              <div class="support-contact-card">
                <h3>Discord Community</h3>
                <p>Ask questions, share feedback, and talk with other Mythic players.</p>
                <a class="btn btn--shadow-discord" href="https://discord.gg/PEDHrhzcnk" target="_blank" rel="noopener">
                  <i class="fa-brands fa-discord" aria-hidden="true"></i>
                  Join Discord
                </a>
              </div>

              <div class="support-contact-card">
                <h3>Freelance / Consulting</h3>
                <p>For development or consulting work outside the Mythic apps, you can contact me through Upwork.</p>
                <a class="btn btn--shadow-primary" href="https://www.upwork.com/fl/~01e352937913645264?mp_source=share" target="_blank" rel="noopener">
                  <i class="fa-slab fa-regular fa-briefcase" aria-hidden="true"></i>
                  Hire me on Upwork
                </a>
              </div>
              <div class="support-contact-card">

              </div>
            </section>
          </div>

          <!-- Right column: Contact form -->
          <div>
            <section class="panel" aria-labelledby="contact-form-title">
              <h2 id="contact-form-title">Send a Message</h2>
              <form id="contact-form" action={`https://submit-form.com/${FORMSPARK_FORM_ID}`} method="post" class="contact-form">

                <div class="form-field">
                  <label for="name">Name</label>
                  <input type="text" id="name" name="name" required maxlength="256" placeholder="Your name">
                </div>

                <div class="form-field">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email" required maxlength="256" placeholder="your@email.com">
                </div>

                <div class="form-field">
                  <label for="phone">Phone (optional)</label>
                  <input type="tel" id="phone" name="phone" maxlength="256" placeholder="Your phone number">
                </div>

                <div class="form-field">
                  <label for="message">Message</label>
                  <textarea id="message" name="message" required maxlength="5000" rows="6" placeholder="Tell me what you need help with. For app issues, include your platform and app version."></textarea>
                </div>

                <!-- Cloudflare Turnstile -->
                <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-callback="onTurnstileSuccess"></div>

                <div class="form-field">
                  <button type="submit" id="submit-btn" disabled class="btn btn--shadow-primary">
                    <i class="fa-slab fa-regular fa-paper-plane" aria-hidden="true"></i>
                    Send Message
                  </button>
                </div>

                <!-- Form Messages -->
                <div class="form-messages">
                  <div id="form-success" class="form-success">
                    <strong>Thank you!</strong> Your message has been sent. I'll reply as soon as I can.
                  </div>

                  <div id="form-error" class="form-error">
                    <strong>Something went wrong.</strong> Please try again, or email me directly at jason@jasonholtdigital.com.
                  </div>
                </div>
              </form>
            </section>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Tab functionality
  function initTabs() {
    const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab-button');
    const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');

    const openTab = (index: number) => {
      tabButtons.forEach((btn, btnIndex) => {
        const isActive = btnIndex === index;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      tabContents.forEach((content, contentIndex) => {
        content.classList.toggle('active', contentIndex === index);
      });
    };

    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        openTab(index);
      });
    });

    const hash = window.location.hash;
    if (hash === '#contact-panel') {
      openTab(1);
    } else {
      openTab(0);
    }
  }

  // Turnstile callback function
  function onTurnstileSuccess(token: string) {
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    if (submitBtn) submitBtn.disabled = false;

    // Add the token to the form as a hidden input
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    let tokenInput = document.getElementById('cf-turnstile-response') as HTMLInputElement | null;
    if (!tokenInput) {
      tokenInput = document.createElement('input');
      tokenInput.type = 'hidden';
      tokenInput.name = 'cf-turnstile-response';
      tokenInput.id = 'cf-turnstile-response';
      form.appendChild(tokenInput);
    }
    tokenInput.value = token;
  }
  ;(window as any).onTurnstileSuccess = onTurnstileSuccess;

  // Handle form submission
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // In dev, when env vars are not set we use action '#'. Prevent network calls.
      if ((e.currentTarget as HTMLFormElement)?.action === '#') {
        alert('Form is not configured yet (dev). Set PUBLIC_FORMSPARK_FORM_ID and PUBLIC_TURNSTILE_SITE_KEY to enable submissions.');
        return false;
      }

      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      const turnstileToken = document.getElementById('cf-turnstile-response') as HTMLInputElement | null;
      const successDiv = document.getElementById('form-success') as HTMLElement | null;
      const errorDiv = document.getElementById('form-error') as HTMLElement | null;

      // Hide previous messages
      if (successDiv) successDiv.style.display = 'none';
      if (errorDiv) errorDiv.style.display = 'none';

      if (!turnstileToken || !turnstileToken.value) {
        alert('Please complete the security verification.');
        return false;
      }

      // Show loading state — save and restore child nodes to preserve icon
      const savedChildren = submitBtn ? Array.from(submitBtn.childNodes) : [];
      if (submitBtn) {
        submitBtn.textContent = '';
        const spinner = document.createElement('i');
        spinner.className = 'fa-solid fa-spinner fa-spin';
        spinner.setAttribute('aria-hidden', 'true');
        submitBtn.appendChild(spinner);
        submitBtn.appendChild(document.createTextNode(' Sending...'));
        submitBtn.disabled = true;
      }

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          // Success
          if (successDiv) successDiv.style.display = 'block';
          form.reset();
          // Reset Turnstile
          (window as any).turnstile?.reset();
        } else {
          // Error
          if (errorDiv) errorDiv.style.display = 'block';
        }
      } catch (error) {
        console.error('Form submission error:', error);
        if (errorDiv) errorDiv.style.display = 'block';
      } finally {
        // Reset button
        if (submitBtn) {
          submitBtn.textContent = '';
          savedChildren.forEach(node => submitBtn.appendChild(node));
          submitBtn.disabled = true; // Disabled until Turnstile is completed again
        }
      }
    });
  }

  // FAQ Accordion functionality
  function initFAQAccordion() {
    // Handle section headers
    const sectionHeaders = document.querySelectorAll<HTMLButtonElement>('.faq-section-header');
    sectionHeaders.forEach((header) => {
      header.addEventListener('click', () => {
        const isExpanded = header.getAttribute('aria-expanded') === 'true';
        const targetId = header.getAttribute('aria-controls');
        const content = targetId ? document.getElementById(targetId) : null;

        // Toggle section
        header.setAttribute('aria-expanded', (!isExpanded).toString());
        if (content) {
          if (isExpanded) {
            content.classList.remove('open');
            // Collapse all Q&A items in this section
            const questions = content.querySelectorAll<HTMLButtonElement>('.faq-question');
            const answers = content.querySelectorAll<HTMLElement>('.faq-answer');
            questions.forEach((q) => q.setAttribute('aria-expanded', 'false'));
            answers.forEach((a) => a.classList.remove('open'));
          } else {
            content.classList.add('open');
          }
        }
      });

      // Handle keyboard navigation for section headers
      header.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          header.click();
        }
      });
    });

    // Handle individual FAQ questions
    const questions = document.querySelectorAll<HTMLButtonElement>('.faq-question');
    questions.forEach((question) => {
      question.addEventListener('click', () => {
        const isExpanded = question.getAttribute('aria-expanded') === 'true';
        const targetId = question.getAttribute('aria-controls');
        const answer = targetId ? document.getElementById(targetId) : null;

        // Toggle Q&A
        question.setAttribute('aria-expanded', (!isExpanded).toString());
        if (answer) {
          if (isExpanded) {
            answer.classList.remove('open');
          } else {
            answer.classList.add('open');
          }
        }
      });

      // Handle keyboard navigation for questions
      question.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          question.click();
        }
      });
    });

    // Initialize: First section open by default
    const firstSection = document.querySelector<HTMLButtonElement>('.faq-section-header[aria-expanded="true"]');
    if (firstSection) {
      const targetId = firstSection.getAttribute('aria-controls');
      const content = targetId ? document.getElementById(targetId) : null;
      if (content) {
        content.classList.add('open');
      }
    }
  }

  // Initialize everything when DOM is loaded
  document.addEventListener('DOMContentLoaded', function () {
    initTabs();
    initContactForm();
    initFAQAccordion();
  });
</script>
