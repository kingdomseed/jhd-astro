---
import V2RefinedFooter from "../../../components/v2/refined/V2RefinedFooter.astro";
import V2RefinedHeader from "../../../components/v2/refined/V2RefinedHeader.astro";
import V2RefinedTweaksPanel from "../../../components/v2/refined/V2RefinedTweaksPanel.astro";
import V2RefinedUtilBar from "../../../components/v2/refined/V2RefinedUtilBar.astro";
import V2RefinedLayout from "../../../layouts/V2RefinedLayout.astro";
import { extractLegalArticle } from "../../../lib/v2Legal";
import termsSource from "../../terms.astro?raw";

const legalArticle = extractLegalArticle(termsSource, "terms.astro");
---

<V2RefinedLayout
  title="Terms of Service - Jason Holt Digital"
  description="Terms of Service for Mythic GME Apps: license, purchases and refunds, acceptable use, disclaimers, and limitations of liability."
  canonicalPath="/v2/terms/"
  mainClass="v2-legal-main"
  theme="munoz"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/v2/assets/detail.css" />
  </Fragment>

  <V2RefinedUtilBar slot="before-main" />
  <V2RefinedHeader slot="before-main" />

  <section class="v2-page-hero" aria-labelledby="terms-title">
    <div class="wrap v2-page-hero__grid">
      <div class="v2-page-hero__copy">
        <p class="eyebrow"><span class="eyebrow-num">01</span>Legal</p>
        <h1 id="terms-title" class="v2-page-title">Terms of <em>Service</em>.</h1>
        <p class="v2-page-lead">
          License terms, purchases and refunds, acceptable use, and limitations.
          Last updated: August 27, 2025.
        </p>
        <ul class="v2-page-meta" aria-label="Terms highlights">
          <li class="v2-page-pill">Personal play license</li>
          <li class="v2-page-pill">Store-managed purchases</li>
          <li class="v2-page-pill">Word Mill license notice</li>
        </ul>
      </div>
      <aside class="v2-page-card">
        <strong>Clear terms</strong>
        <p>Fair use, official content boundaries, support expectations, and the practical legal bits in one place.</p>
      </aside>
    </div>
  </section>

  <section class="v2-article-shell">
    <div class="wrap v2-article-grid">
      <article class="v2-article-panel">
        <div class="v2-article-inner" set:html={legalArticle} />
      </article>
      <aside class="v2-article-aside" aria-label="Legal actions">
        <div class="v2-aside-card">
          <h2>Legal questions</h2>
          <p><a href="mailto:legal@jasonholtdigital.com">legal@jasonholtdigital.com</a></p>
        </div>
        <div class="v2-aside-card">
          <h2>Privacy</h2>
          <p><a href="/v2/privacy/">Read the Privacy Policy</a></p>
        </div>
      </aside>
    </div>
  </section>

  <V2RefinedFooter slot="after-main" />
  <V2RefinedTweaksPanel slot="after-main" />
</V2RefinedLayout>
