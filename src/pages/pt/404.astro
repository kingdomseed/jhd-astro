---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
---
<BaseLayout
  title="404 — Página Não Encontrada | Apps Mythic GME"
  description="Desculpe, não conseguimos encontrar essa página. Tente a página inicial, Apps, Suporte ou Contato."
  canonicalPath="/pt/404/"
  lang="pt"
  alternatePath="/404/"
  mainClass="error-main"
>
  <PageHeader
    title="404 — Página Não Encontrada"
    subtitle="Ops! Algo desapareceu"
    description="A página que você está procurando não existe ou pode ter mudado de lugar. Vamos colocar você de volta nos trilhos."
    accent="Erro"
    layout="left"
    icon="fa-solid fa-triangle-exclamation"
    colorScheme="accent"
  />

  <section class="section" aria-labelledby="nf-title">
    <div class="container">
      <header class="section-head" aria-hidden="true">
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">404</span>
      </header>
      <div class="error-card">
        <h1 id="nf-title" class="error-title">
          Página não encontrada
        </h1>
        <p class="error-summary">
          A página que você estava procurando não existe
          ou pode ter mudado. Escolha um destino abaixo.
        </p>
        <div class="error-actions">
          <a class="btn btn--shadow-primary" href="/pt/">
            <i
              class="fa-slab fa-regular fa-house"
              aria-hidden="true"></i>
            Início
          </a>
          <a
            class="btn btn--shadow-accent"
            href="/pt/apps"
          >
            <i
              class="fa-slab fa-regular fa-rocket"
              aria-hidden="true"></i>
            Apps
          </a>
          <a
            class="btn btn--shadow-primary"
            href="/pt/resources"
          >
            <i
              class="fa-slab fa-regular fa-book-open"
              aria-hidden="true"></i>
            Recursos
          </a>
          <a
            class="btn btn--shadow-primary"
            href="/pt/support"
          >
            <i
              class="fa-slab fa-regular fa-life-ring"
              aria-hidden="true"></i>
            Suporte
          </a>
          <a
            class="btn btn--shadow-primary"
            href="/pt/blog"
          >
            <i
              class="fa-slab fa-regular fa-newspaper"
              aria-hidden="true"></i>
            Blog
          </a>
          <a
            class="btn btn--shadow-primary"
            href="/pt/support#contact-panel"
          >
            <i
              class="fa-slab fa-regular fa-envelope"
              aria-hidden="true"></i>
            Contato
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
