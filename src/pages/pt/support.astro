---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';

const FORMSPARK_FORM_ID = "BrXEDLTap";
const TURNSTILE_SITE_KEY = "0x4AAAAAABhU6Cccio-kREUw";
---
<BaseLayout
  title="Suporte e Contato | Apps Mythic GME"
  description="Encontre suporte, Discord, FAQ e opções de contato para Mythic GME Mobile e Mythic GME Digital."
  canonicalPath="/pt/support/"
  lang="pt"
  alternatePath="/support/"
  mainClass="support-main"
>
  <Fragment slot="head">
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script>
  </Fragment>

  <PageHeader
    title="Suporte e Contato"
    subtitle="Encontre ajuda, tire dúvidas ou envie uma mensagem"
    description="Suporte do app, ajuda da comunidade, respostas do FAQ e opções de contato direto em um só lugar."
    accent="Suporte"
    layout="left"
    icon="fa-solid fa-life-ring"
    visualElement="particles"
    colorScheme="accent"
  />
                <section class="section" aria-labelledby="support-tabs-title">
                    <div class="container support-container">
                        <header class="section-head" aria-hidden="true">
                            <span class="accent-line" aria-hidden="true"></span>
                            <span class="badge-text">Suporte</span>
                        </header>
                        <div class="support-intro">
                            <h2 id="support-tabs-title" class="section-title">
                                Encontre o caminho certo para ajuda
                            </h2>
                            <p class="support-intro__summary">
                                Use o Discord para dúvidas da comunidade,
                                envie e-mail para suporte detalhado ou consulte
                                o FAQ para respostas comuns.
                            </p>
                        </div>

                        <div class="support-tabs" role="presentation">
                            <ul class="tab-nav" role="tablist">
                                <li>
                                    <button
                                        class="tab-button active"
                                        role="tab"
                                        aria-selected="true"
                                        aria-controls="support-panel"
                                        id="support-tab"
                                    >
                                        <i
                                            class="fa-slab fa-regular fa-life-ring"
                                            aria-hidden="true"></i>
                                        Suporte e FAQ
                                    </button>
                                </li>
                                <li>
                                    <button
                                        class="tab-button"
                                        role="tab"
                                        aria-selected="false"
                                        aria-controls="contact-panel"
                                        id="contact-tab"
                                    >
                                        <i
                                            class="fa-slab fa-regular fa-envelope"
                                            aria-hidden="true"></i>
                                        Contato
                                    </button>
                                </li>
                            </ul>
                        </div>

                        <div
                            id="support-panel"
                            class="tab-content active"
                            role="tabpanel"
                            aria-labelledby="support-tab"
                        >
                            <section aria-labelledby="help-title">
                                <h2 id="help-title">Como Obter Ajuda</h2>
                                <div class="twoup">
                                    <div class="panel">
                                        <h3>Discord</h3>
                                        <p>
                                            Tire dúvidas, compartilhe feedback e
                                            converse com outros jogadores de
                                            Mythic.
                                        </p>
                                        <p>
                                            <a
                                                class="btn btn--shadow-discord"
                                                href="https://discord.gg/PEDHrhzcnk"
                                                target="_blank"
                                                rel="noopener"
                                            >
                                                <i
                                                    class="fa-brands fa-discord"
                                                    aria-hidden="true"></i>
                                                Entrar no Discord
                                            </a>
                                        </p>
                                    </div>
                                    <div class="panel">
                                        <h3>Suporte por E-mail</h3>
                                        <p>
                                            Envie problemas detalhados,
                                            perguntas sobre conta ou pedidos
                                            privados de suporte por e-mail.
                                        </p>
                                        <p>
                                            <a
                                                class="btn btn--shadow-primary"
                                                href="mailto:support@jasonholtdigital.com"
                                            >
                                                <i
                                                    class="fa-slab fa-regular fa-envelope"
                                                    aria-hidden="true"></i>
                                                Enviar E-mail
                                            </a>
                                        </p>
                                    </div>
                                </div>
                            </section>

                            <section id="faqs" aria-labelledby="faqs-title">
                                <h2 id="faqs-title">FAQ completo</h2>

                                <!-- General & Platforms Section -->
                                <div class="faq-section">
                                    <button
                                        class="faq-section-header"
                                        aria-expanded="true"
                                        aria-controls="general-section"
                                    >
                                        <h3>Geral e Plataformas</h3>
                                        <i
                                            class="fa-solid fa-chevron-down"
                                            aria-hidden="true"></i>
                                    </button>
                                    <div
                                        id="general-section"
                                        class="faq-section-content"
                                    >
                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="what-is-mythic"
                                            >
                                                <strong
                                                    >O que é Mythic GME Mobile /
                                                    Digital?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="what-is-mythic"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    São os apps oficiais Mythic
                                                    GME 2e, criados em parceria
                                                    com a Word Mill Creative.
                                                    Eles ajudam você a responder
                                                    perguntas ao Destino, rolar
                                                    em Tabelas de Significado,
                                                    gerenciar Listas e Cenas e
                                                    manter o jogo andando
                                                    offline.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="who-makes"
                                            >
                                                <strong>Quem faz?</strong>
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="who-makes"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Os apps são criados e
                                                    mantidos pela Jason Holt
                                                    Digital em parceria com a
                                                    Word Mill Creative.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="where-get"
                                            >
                                                <strong
                                                    >Onde posso conseguir?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="where-get"
                                                class="faq-answer"
                                            >
                                                <ul>
                                                    <li>
                                                        <strong
                                                            >Apple App Store:</strong
                                                        > iPhone • iPad • macOS (Compra
                                                        Universal)
                                                    </li>
                                                    <li>
                                                        <strong
                                                            >Google Play:</strong
                                                        > Celulares e tablets Android
                                                    </li>
                                                    <li>
                                                        <strong
                                                            >Amazon Appstore:</strong
                                                        > Tablets Fire
                                                    </li>
                                                    <li>
                                                        <strong
                                                            >Windows Store:</strong
                                                        > Windows 10 e 11
                                                    </li>
                                                    <li>
                                                        <strong>Itch.io:</strong
                                                        > Versões Windows, macOS
                                                        e Linux (Flatpak) sem DRM
                                                        (Compra Universal)
                                                    </li>
                                                    <li>
                                                        <strong>Steam:</strong> planejado
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="worldwide"
                                            >
                                                <strong
                                                    >Está disponível
                                                    mundialmente?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="worldwide"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Sim. Disponibilidade e
                                                    preços variam por
                                                    loja/região.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="cross-platform"
                                            >
                                                <strong
                                                    >Se eu comprar o app em uma
                                                    plataforma, preciso comprar
                                                    em outra?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="cross-platform"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Sim. Cada plataforma requer
                                                    seus próprios custos de
                                                    desenvolvimento e
                                                    investimento de tempo. A
                                                    única exceção é o sistema de
                                                    compra universal da Apple
                                                    App Store e a plataforma
                                                    Itch.io, que permite comprar
                                                    o app em uma plataforma e
                                                    ter acesso para baixar o app
                                                    para outras plataformas
                                                    também.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="need-book"
                                            >
                                                <strong
                                                    >Eu preciso do livro de
                                                    regras do Mythic GME 2e?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="need-book"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    O app é um companheiro para
                                                    o livro, então o livro é
                                                    altamente recomendado e
                                                    efetivamente necessário. O
                                                    app implementa/acelera o
                                                    Mythic, mas o livro ensina o
                                                    sistema, variantes, e inclui
                                                    muitos exemplos e regras
                                                    alternativas que você pode
                                                    aplicar.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Features & Data Section -->
                                <div class="faq-section">
                                    <button
                                        class="faq-section-header"
                                        aria-expanded="false"
                                        aria-controls="features-section"
                                    >
                                        <h3>Recursos e Dados</h3>
                                        <i
                                            class="fa-solid fa-chevron-down"
                                            aria-hidden="true"></i>
                                    </button>
                                    <div
                                        id="features-section"
                                        class="faq-section-content"
                                    >
                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="core-features"
                                            >
                                                <strong
                                                    >Recursos principais</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="core-features"
                                                class="faq-answer"
                                            >
                                                <ul>
                                                    <li>
                                                        Tabela de Destino e
                                                        Verificação de Destino
                                                        com Fator de Caos
                                                    </li>
                                                    <li>
                                                        Eventos Aleatórios e
                                                        tabelas de Foco de
                                                        Evento
                                                    </li>
                                                    <li>
                                                        Testes de Cena e Ajustes
                                                        de Cena
                                                    </li>
                                                    <li>
                                                        Tabelas de Significado,
                                                        incluindo as tabelas
                                                        oficiais do Mythic GME
                                                        2e e tabelas adicionais
                                                        de Mythic Magazines e
                                                        Variations por meio dos
                                                        Recursos Expandidos
                                                    </li>
                                                    <li>
                                                        Listas para
                                                        Personagens, Tramas e
                                                        Características, com
                                                        suporte a Aventuras
                                                        Preparadas
                                                    </li>
                                                    <li>
                                                        Cenas com títulos,
                                                        resumos, Fator de Caos e
                                                        notas
                                                    </li>
                                                    <li>
                                                        Rolador de Dados:
                                                        suporta notações como
                                                        1d6, 2d10+3, 4d6kh3 e
                                                        muito mais, e salva suas
                                                        fórmulas para rolagens
                                                        comuns
                                                    </li>
                                                    <li>
                                                        Diários e o Diário de
                                                        Aventura para acompanhar
                                                        o jogo em andamento
                                                    </li>
                                                    <li>
                                                        Exportação de Diários em
                                                        JSON e Markdown para
                                                        backup e compartilhamento
                                                    </li>
                                                    <li>
                                                        Sincronização iCloud em
                                                        dispositivos Apple e
                                                        locais de armazenamento
                                                        personalizados nas
                                                        plataformas não Apple
                                                        compatíveis
                                                    </li>
                                                    <li>
                                                        Conteúdo de Recursos
                                                        Expandidos de Mythic
                                                        Magazines e Variations
                                                    </li>
                                                    <li>
                                                        Tabelas Personalizadas
                                                        para criar, editar,
                                                        importar, exportar,
                                                        marcar e vincular suas
                                                        próprias tabelas oráculo
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="accessibility"
                                            >
                                                <strong>Acessibilidade</strong>
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="accessibility"
                                                class="faq-answer"
                                            >
                                                <ul>
                                                    <li>
                                                        Suporte a <strong
                                                            >leitor de tela</strong
                                                        > nas principais plataformas.
                                                    </li>
                                                    <li>
                                                        Paletas amigáveis para <strong
                                                            >daltonismo</strong
                                                        > para contraste melhorado.
                                                    </li>
                                                    <li>
                                                        Opções de <strong
                                                            >texto grande/muito
                                                            grande</strong
                                                        > que escalam a UI principal.
                                                    </li>
                                                    <li>
                                                        <strong
                                                            >Modo para canhotos</strong
                                                        > para uso confortável com
                                                        uma mão.
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="languages"
                                            >
                                                <strong>Idiomas</strong>
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="languages"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Os apps incluem a
                                                    localização oficial em
                                                    português brasileiro da
                                                    RetroPunk Publicações.
                                                </p>
                                                <p>
                                                    Italiano, francês, alemão e
                                                    espanhol incluem
                                                    localizações traduzidas por
                                                    máquina para Tabelas de
                                                    Significado e tabelas de
                                                    Foco de Evento.
                                                </p>
                                                <p>
                                                    Você também pode usar
                                                    Tabelas Personalizadas para
                                                    criar ou ajustar suas
                                                    próprias tabelas localizadas.
                                                    Espero oferecer mais
                                                    localizações oficiais com o
                                                    tempo.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Purchases, Pricing & Upgrades Section -->
                                <div class="faq-section">
                                    <button
                                        class="faq-section-header"
                                        aria-expanded="false"
                                        aria-controls="pricing-section"
                                    >
                                        <h3>Compras, Preços e Atualizações</h3>
                                        <i
                                            class="fa-solid fa-chevron-down"
                                            aria-hidden="true"></i>
                                    </button>
                                    <div
                                        id="pricing-section"
                                        class="faq-section-content"
                                    >
                                        <p>
                                            <em
                                                >Última revisão: 27 de maio de
                                                2026</em>
                                        </p>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="new-app"
                                            >
                                                <strong
                                                    >Por que uma nova listagem
                                                    de app?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="new-app"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    O desenvolvedor original
                                                    fechou seu negócio e parou o
                                                    trabalho no app legado.
                                                    Alguns meses depois,
                                                    reiniciei o desenvolvimento
                                                    sob a Jason Holt Digital.
                                                    Como as contas da loja
                                                    mudaram e a base de código
                                                    foi reconstruída,
                                                    Apple/Google/Amazon tratam
                                                    isso como um novo produto,
                                                    então não pode ser entregue
                                                    como uma atualização
                                                    gratuita para a listagem
                                                    antiga.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="pricing-store"
                                            >
                                                <strong
                                                    >Preços e compras por loja</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="pricing-store"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Apple, Google Play e Amazon
                                                    vendem o app base com um
                                                    desbloqueio único de
                                                    Recursos Expandidos. A
                                                    Microsoft Store e o itch.io
                                                    vendem Mythic GME Digital
                                                    como uma compra única para
                                                    desktop.
                                                </p>
                                                <p>
                                                    As páginas das lojas mostram
                                                    o preço atual no seu país,
                                                    incluindo impostos locais ou
                                                    preços regionais.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="subscription"
                                            >
                                                <strong
                                                    >Isso é uma assinatura?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="subscription"
                                                class="faq-answer"
                                            >
                                                <p>
                                                    Não. Lojas mobile usam um
                                                    desbloqueio de Recursos
                                                    Expandidos único. Lojas
                                                    desktop incluem o conjunto
                                                    de recursos do desktop desde
                                                    o início.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="expanded-features"
                                            >
                                                <strong
                                                    >Como funciona o desbloqueio
                                                    de Recursos Expandidos?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="expanded-features"
                                                class="faq-answer"
                                            >
                                                <ul>
                                                    <li>
                                                        Quando você compra o
                                                        desbloqueio, você mantém
                                                        os Recursos Expandidos
                                                        disponíveis naquele
                                                        momento.
                                                    </li>
                                                    <li>
                                                        Pelos próximos 12 meses,
                                                        novos Recursos
                                                        Expandidos adicionados
                                                        ao app também ficam
                                                        desbloqueados para você
                                                        permanentemente.
                                                    </li>
                                                    <li>
                                                        Depois dessa janela, o
                                                        app continua recebendo
                                                        correções e melhorias.
                                                        Novos Recursos
                                                        Expandidos podem exigir
                                                        um novo desbloqueio se
                                                        você decidir que vale a
                                                        pena adicioná-los.
                                                    </li>
                                                    <li>
                                                        Tudo o que você
                                                        desbloquear continua
                                                        desbloqueado.
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="included-today"
                                            >
                                                <strong
                                                    >O que está incluído nos
                                                    Recursos Expandidos hoje?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="included-today"
                                                class="faq-answer"
                                            >
                                                <ul>
                                                    <li>
                                                        Tabelas de Significado
                                                        adicionais de Mythic
                                                        Magazines e Variations.
                                                    </li>
                                                    <li>
                                                        Tabelas adicionais de
                                                        Foco de Evento de Mythic
                                                        Magazines e Variations.
                                                    </li>
                                                    <li>
                                                        Tabelas Personalizadas
                                                        para criar, editar,
                                                        importar, exportar,
                                                        marcar, categorizar e
                                                        vincular suas próprias
                                                        tabelas oráculo.
                                                    </li>
                                                    <li>Jogo Híbrido.</li>
                                                    <li>Trilhas de Progresso.</li>
                                                    <li>Discovery Check.</li>
                                                    <li>Cenas Chaveadas.</li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="planned-premium"
                                            >
                                                <strong
                                                    >Roadmap de Recursos
                                                    Expandidos</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="planned-premium"
                                                class="faq-answer"
                                            >
                                                <p>Itens do roadmap podem mudar.</p>
                                                <ul>
                                                    <li>Anotações aprimoradas.</li>
                                                    <li>Fichas de personagem.</li>
                                                    <li>Ações de NPCs.</li>
                                                    <li>Suporte a imagens.</li>
                                                    <li>Listas Personalizadas.</li>
                                                </ul>
                                            </div>
                                        </div>

                                        <div class="faq-item">
                                            <button
                                                class="faq-question"
                                                aria-expanded="false"
                                                aria-controls="old-app-questions"
                                            >
                                                <strong
                                                    >Perguntas sobre o app
                                                    antigo vs este?</strong
                                                >
                                                <i
                                                    class="fa-solid fa-chevron-down"
                                                    aria-hidden="true"></i>
                                            </button>
                                            <div
                                                id="old-app-questions"
                                                class="faq-answer"
                                            >
                                                <p>
