---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UtilBar from '../../components/layout/UtilBar.astro';
import Hero from '../../components/home/Hero.astro';
import Billboard from '../../components/home/Billboard.astro';
import CoreBenefits from '../../components/home/CoreBenefits.astro';
import CommunitySupport from '../../components/home/CommunitySupport.astro';
import Partners from '../../components/home/Partners.astro';
import PopularResources from '../../components/home/PopularResources.astro';
import MakersNote from '../../components/home/MakersNote.astro';
import ReviewsRotator from '../../components/home/ReviewsRotator.astro';
---
<BaseLayout
  title="Apps oficiais Mythic GME 2e — Jason Holt Digital"
  description="RPG sem mestre na ponta dos dedos. Apps companheiros oficiais licenciados para Mythic GME 2e, disponíveis para mobile e desktop."
  canonicalPath="/pt/"
  lang="pt"
  alternatePath="/"
  ogTitle="Apps oficiais Mythic GME 2e — Jason Holt Digital"
  ogDescription="RPG sem mestre na ponta dos dedos. Apps oficiais licenciados para Mythic GME 2e no mobile e no desktop."
>
  <UtilBar slot="before-header" />
  <Fragment slot="head">
    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Mythic GME 2e Apps",
        "description": "Apps companheiros oficiais licenciados para Mythic GME 2e no mobile e no desktop.",
        "applicationCategory": "Game",
        "operatingSystem": ["iOS", "Android", "Windows", "macOS", "Linux"],
        "url": "https://jasonholtdigital.com/pt/",
        "inLanguage": "pt-BR",
        "publisher": {
          "@type": "Person",
          "name": "Jason Holt",
          "url": "https://jasonholtdigital.com"
        }
      }
    </script>
  </Fragment>

  <Hero />
  <Billboard />
  <ReviewsRotator />
  <CoreBenefits />
  <CommunitySupport />
  <Partners />
  <PopularResources />
  <MakersNote />
</BaseLayout>
