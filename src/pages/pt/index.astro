---
// Page component that assembles all of the individual
// pieces of the landing page.  Each section of the design lives
// in its own component to promote reusability and clarity.  When
// consumed within an Astro project, these components render
// static HTML that closely mirrors the original design.
import BaseLayout from '../../layouts/BaseLayout.astro';
import UtilBar from '../../components/layout/UtilBar.astro';
import Hero from '../../components/home/Hero.astro';
import Billboard from '../../components/home/Billboard.astro';
import CoreBenefits from '../../components/home/CoreBenefits.astro';
import CommunitySupport from '../../components/home/CommunitySupport.astro';
import Partners from '../../components/home/Partners.astro';
import PopularResources from '../../components/home/PopularResources.astro';
import MakersNote from '../../components/home/MakersNote.astro';
import ReviewsRotator from '../../components/home/ReviewsRotator.astro';
---
<BaseLayout
  title="Aplicativos Oficiais Mythic GME 2e — Jason Holt Digital"
  description="RPG Sem Mestre na ponta dos dedos. Aplicativos oficiais licenciados de Mythic GME 2e por Jason Holt Digital. Baixe para mobile e desktop."
  canonicalPath="/pt/"
  lang="pt"
  ogTitle="Aplicativos Oficiais Mythic GME 2e — Jason Holt Digital"
  ogDescription="RPG Sem Mestre na ponta dos dedos. Aplicativos oficiais licenciados de Mythic GME 2e por Jason Holt Digital."
>
  <UtilBar slot="before-header" />
  <Fragment slot="head">
    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Mythic GME 2e Apps",
        "description": "Official licensed companion apps for Mythic GME 2e oracle-style solo RPG",
        "applicationCategory": "Game",
        "operatingSystem": ["iOS", "Android", "Windows", "macOS", "Linux"],
        "offers": [
          {
            "@type": "Offer",
            "price": "9.99",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "url": "https://apps.apple.com/us/app/mythic-gme-mobile/id6726999147"
          }
        ],
        "publisher": {
          "@type": "Person",
          "name": "Jason Holt",
          "url": "https://jasonholtdigital.com"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.7",
          "ratingCount": "100"
        }
      }
    </script>
  </Fragment>

  <!-- Hero section introduces the product and invites download -->
  <Hero />
  <!-- Billboard preview of the application screenshot -->
  <Billboard />
  <!-- Rotating reviews / social proof strip (from design) -->
  <ReviewsRotator />
  <!-- Core benefits of using the Mythic GME apps -->
  <CoreBenefits />
  <!-- Community and support channels -->
  <CommunitySupport />
  <!-- Official partners -->
  <Partners />
  <!-- Teaser list of documentation resources -->
  <PopularResources />
  <!-- Personal note from the maker of the product -->
  <MakersNote />
</BaseLayout>
