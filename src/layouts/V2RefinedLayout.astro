---
import V2RefinedInteractions from "../components/v2/refined/V2RefinedInteractions.astro";
import { v2AssetPath } from "../lib/v2Links";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  mainClass?: string;
  noindex?: boolean;
  theme?: "refined" | "editorial" | "munoz";
}

const {
  title = "Jason Holt Digital - Official Mythic GME Apps",
  description = "Official Mythic GME companion apps, resources, release notes, and support from Jason Holt Digital.",
  canonicalPath = Astro.url.pathname,
  mainClass,
  noindex = true,
  theme = "munoz",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://jasonholtdigital.com");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={v2AssetPath("logo.svg")} />
    <link rel="stylesheet" href={v2AssetPath("tokens.css")} />
    <link rel="stylesheet" href={v2AssetPath("themes.css")} />
    <link rel="stylesheet" href={v2AssetPath("page.css")} />
    <link rel="stylesheet" href={v2AssetPath("shell.css")} />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Bitter:wght@400;500;600;700;800;900&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700;9..144,800;9..144,900&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body data-theme={theme}>
    <a class="skip-link" href="#main">Skip to main content</a>
    <div class="noise-overlay" aria-hidden="true"></div>
    <slot name="before-main" />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <slot name="after-main" />
    <V2RefinedInteractions />
  </body>
</html>
