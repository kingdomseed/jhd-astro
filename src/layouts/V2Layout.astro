---
interface Props {
  title?: string;
  description?: string;
  theme?: "refined" | "editorial" | "munoz";
}

const {
  title = "Jason Holt Digital - V2 Preview",
  description = "V2 redesign scaffold for Jason Holt Digital.",
  theme = "refined",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Bitter:wght@400;500;600;700;800;900&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700;9..144,800;9..144,900&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/v2.css" />
    <script
      is:inline
      src="https://kit.fontawesome.com/9f0db3cdf4.js"
      crossorigin="anonymous"></script>
    <slot name="head" />
  </head>
  <body data-theme={theme} class="v2-body">
    <div class="v2-noise-overlay" aria-hidden="true"></div>
    <div class="v2-site">
      <slot />
    </div>
  </body>
</html>
