<div id="tweaks" aria-label="Tweaks">
  <h4>Tweaks <small>muñoz</small></h4>
  <div class="group">
    <label>Primary accent (teal)</label>
    <div class="pills" data-set="primary">
      <button class="pill on" data-val="default">Default</button>
      <button class="pill" data-val="#1e6b78">Teal</button>
      <button class="pill" data-val="#0e4751">Deep Teal</button>
      <button class="pill" data-val="#3a1f1f">Oxblood</button>
      <button class="pill" data-val="#2a4d3a">Forest</button>
    </div>
  </div>
  <div class="group">
    <label>Secondary accent (coral)</label>
    <div class="pills" data-set="secondary">
      <button class="pill on" data-val="default">Default</button>
      <button class="pill" data-val="#d0503a">Coral</button>
      <button class="pill" data-val="#e8a32a">Ochre</button>
      <button class="pill" data-val="#b8442f">Brick</button>
      <button class="pill" data-val="#c97b3d">Amber</button>
    </div>
  </div>
  <div class="group">
    <label>Paper warmth</label>
    <div class="pills" data-set="paper">
      <button class="pill on" data-val="default">Default</button>
      <button class="pill" data-val="#f5efdf">Light</button>
      <button class="pill" data-val="#ede6d5">Aged</button>
      <button class="pill" data-val="#e3dac4">Parchment</button>
    </div>
  </div>
  <div class="group">
    <label>Corners</label>
    <div class="pills" data-set="round">
      <button class="pill on" data-val="hard">Hard</button>
      <button class="pill" data-val="soft">Soft</button>
    </div>
  </div>
  <div class="group">
    <label>Density</label>
    <div class="pills" data-set="density">
      <button class="pill" data-val="cozy">Cozy</button>
      <button class="pill on" data-val="default">Default</button>
      <button class="pill" data-val="airy">Airy</button>
    </div>
  </div>
  <div style="font-family:var(--font-mono); font-size: 10px; color: var(--jhd-ink-faint); margin-top: 10px; letter-spacing: .05em;">Press ⌘. to toggle</div>
</div>
