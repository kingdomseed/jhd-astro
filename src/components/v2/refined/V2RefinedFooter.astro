---
import {
  v2AssetPath,
  v2ContactUrl,
  v2DiscordUrl,
  v2ReleaseNotesUrl,
  v2StoreLinks,
  v2SupportUrl,
} from "../../../lib/v2Links";
---

<footer class="foot" id="site-footer">
  <img class="foot-art" src={v2AssetPath("stamp-art15.png")} alt="" aria-hidden="true" />
  <div class="wrap" style="position:relative;z-index:2">
    <h2 class="foot-big">Solo play.<br />Shipped <em>honestly</em>.</h2>
    <div class="foot-grid">
      <div class="foot-col">
        <a class="brand" href="/v2/" style="color: var(--jhd-bg); margin-bottom:14px;">
          <span class="brand-mark" style="background: var(--jhd-bg-warm);"><img src={v2AssetPath("logo-munoz.svg")} alt="JHD" /></span>
          <div><span class="brand-title">Jason Holt Digital</span><span class="brand-sub" style="color: color-mix(in oklab, var(--jhd-bg) 55%, transparent);">Indie · Est. 2023</span></div>
        </a>
        <p style="margin:16px 0 0; font-size:13px; color: color-mix(in oklab, var(--jhd-bg) 65%, transparent); max-width: 280px; line-height:1.55;">Official Mythic GME 2e Apps. Licensed by Word Mill Games. Made one ship at a time.</p>
      </div>
      <div class="foot-col">
        <h4>Product</h4>
        <a href="/v2/apps/">Apps</a>
        <a href="/v2/resources/">Resources</a>
        <a href="/v2/blog/">Blog</a>
        <a href={v2SupportUrl}>Support</a>
        <a href={v2ReleaseNotesUrl}>Changelog</a>
      </div>
      <div class="foot-col">
        <h4>Get the App</h4>
        {v2StoreLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer">
            <i class={link.icon} aria-hidden="true"></i>{link.meta === "Win" ? "Windows" : link.meta}
          </a>
        ))}
      </div>
      <div class="foot-col">
        <h4>Company</h4>
        <a href="/about/">About</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href={v2ContactUrl}>Contact</a>
        <a href={v2DiscordUrl} target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord" aria-hidden="true"></i>Discord</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 Jason Holt Digital. All rights reserved.</span>
      <span>Licensed by Word Mill Games · Mythic GME 2e</span>
    </div>
  </div>
</footer>
