<section class="hero" id="home">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <div class="eyebrow hero-eyebrow">
        <span>Official Mythic GME 2e Apps</span>
        <span class="eyebrow-num">— v2.4</span>
      </div>
      <h1 class="hero-title">GM-less play at <em>your fingertips</em>.</h1>
      <p class="hero-lead">Official, licensed companion to the original oracle-style solo RPG. Roll the Fate Chart, consult Meaning Tables, and keep your scenes, threads and characters in one place.</p>
      <div class="cta-row">
        <a class="btn btn--primary btn--lg" href="/v2/apps/">Get the App <i class="fa-solid fa-arrow-right"></i></a>
        <a class="btn btn--lg" href="/v2/resources/"><i class="fa-solid fa-book-open"></i> Get Resources</a>
      </div>
      <ul class="stats">
        <li class="stat"><span class="stat-n">4.7<i class="fa-solid fa-star" style="font-size:16px;color:var(--jhd-accent);margin-left:4px"></i></span><span class="stat-l">Avg rating</span></li>
        <li class="stat"><span class="stat-n">5,000+</span><span class="stat-l">Installs</span></li>
        <li class="stat"><span class="stat-n">2,000+</span><span class="stat-l">Community</span></li>
        <li class="stat"><span class="stat-n">5</span><span class="stat-l">Platforms</span></li>
      </ul>
    </div>

    <div class="hero-stage">
      <div class="stage-plate"></div>
      <div class="stage-slab"></div>
      <div class="stage-badge">EST. 2023 · LICENSED</div>
      <img class="stage-cutout" src="/v2/assets/stamp-astronaut.png" alt="" aria-hidden="true" />
      <div class="phone-carousel" id="phoneCarousel">
        <div class="phone-slide on"><img src="/v2/assets/mobile-1.png" alt="Fate Chart" data-label="Fate Chart" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-2.png" alt="Scenes" data-label="Scenes" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-3.png" alt="Settings" data-label="Settings" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-4.png" alt="Dice" data-label="Dice Roller" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-5.png" alt="Threads" data-label="Threads" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-6.png" alt="Support" data-label="Support" /></div>
        <div class="phone-slide"><img src="/v2/assets/mobile-7.png" alt="Tables" data-label="Custom Tables" /></div>
        <div class="phone-caption">
          <span id="captLabel">Fate Chart</span>
          <span class="ix" id="captIx">01 / 07</span>
        </div>
        <div class="phone-steps" id="phoneSteps"></div>
      </div>
    </div>
  </div>
