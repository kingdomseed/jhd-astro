---
import {
  v2AssetPath,
  v2AppsAnchorUrl,
  v2NavLinks,
  v2StoreLinks,
} from "../../../lib/v2Links";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/v2/" ? pathname === href : pathname.startsWith(href);
---

<header class="nav" id="nav">
  <div class="wrap nav-row">
    <a class="brand" href="/v2/" aria-label="Jason Holt Digital home">
      <span class="brand-mark"><img src={v2AssetPath("logo-munoz.svg")} alt="JHD" /></span>
      <div>
        <span class="brand-title">Jason Holt Digital</span>
        <span class="brand-sub">Indie Studio · Est. 2023</span>
      </div>
    </a>
    <nav class="nav-main" aria-label="Primary">
      {v2NavLinks.map((link) => (
        <a
          class:list={["nav-link", { active: isActive(link.href) }]}
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          <i class={link.icon} aria-hidden="true"></i>{link.label}
        </a>
      ))}
      <div class="nav-cta-wrap">
        <button
          class="nav-cta"
          id="ctaBtn"
          type="button"
          aria-expanded="false"
          aria-haspopup="menu"
          aria-controls="menu"
        >
          <span>Get the App</span>
          <i class="fa-solid fa-chevron-down chev" aria-hidden="true"></i>
        </button>
        <div class="menu" id="menu" role="menu" aria-label="Choose your platform">
          <div class="menu-head">Choose your platform</div>
          {v2StoreLinks.map((link) => (
            <a
              class={`menu-item ${link.className}`}
              role="menuitem"
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class={link.icon} aria-hidden="true"></i><span>{link.label}</span><span class="meta">{link.meta}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>
    <button
      class="menu-burger"
      id="burger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="drawer"
    >
      <i class="fa-solid fa-bars" aria-hidden="true"></i>
    </button>
  </div>
</header>

<div class="drawer-overlay" id="drawerOverlay" aria-hidden="true"></div>
<aside class="drawer" id="drawer" aria-label="Mobile navigation" aria-hidden="true" inert>
  <button class="drawer-close" id="drawerClose" type="button" aria-label="Close menu"><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
  {v2NavLinks.map((link) => (
    <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
      <i class={link.icon} aria-hidden="true"></i>{link.label}
    </a>
  ))}
  <a href={v2AppsAnchorUrl} style="margin-top:20px; background: var(--jhd-ink); color: var(--jhd-bg); padding: 16px; border-bottom: none;">Get the App →</a>
</aside>
