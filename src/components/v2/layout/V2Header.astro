---
import brandLogoUrl from "../../../assets/logo/logo.svg?url";
---

<header class="v2-header">
  <div class="v2-wrap v2-header__row">
    <a class="v2-brand" href="/v2/" aria-label="Jason Holt Digital V2 preview home">
      <img src={brandLogoUrl} alt="Jason Holt Digital" width="48" height="48" />
      <span>
        <strong>Jason Holt Digital</strong>
        <small>V2 preview scaffold</small>
      </span>
    </a>

    <nav class="v2-nav v2-nav--desktop" aria-label="Preview navigation">
      <a href="/v2/">Home</a>
      <a href="/v2/apps/">Apps</a>
      <a href="/v2/resources/">Docs</a>
      <a href="/v2/#rollout">Rollout</a>
    </nav>

    <div class="v2-header__actions">
      <div class="v2-download" data-v2-download>
        <button
          class="v2-btn v2-btn--primary v2-btn--compact v2-download__button"
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="v2-download-menu"
          data-v2-download-toggle
        >
          <span>Get the apps</span>
          <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
        </button>
        <div
          id="v2-download-menu"
          class="v2-menu"
          role="menu"
          aria-label="Platform downloads"
          data-v2-download-menu
        >
          <p class="v2-menu__label">Downloads</p>
          <a role="menuitem" href="https://apps.apple.com/us/app/mythic-gme-mobile/id6726999147" target="_blank" rel="noopener noreferrer">Apple App Store</a>
          <a role="menuitem" href="https://play.google.com/store/apps/details?id=com.jasonholtdigital.mythicgme2e" target="_blank" rel="noopener noreferrer">Google Play</a>
          <a role="menuitem" href="https://www.amazon.ca/Jason-Holt-Digital-LLC-Mythic/dp/B0DJBPF9L9" target="_blank" rel="noopener noreferrer">Amazon Appstore</a>
          <a role="menuitem" href="https://apps.microsoft.com/detail/9n39b8hj3cdg" target="_blank" rel="noopener noreferrer">Microsoft Store</a>
          <a role="menuitem" href="https://jasonholtdigital.itch.io/mythic-gme-digital" target="_blank" rel="noopener noreferrer">itch.io</a>
        </div>
      </div>

      <button
        class="v2-burger"
        type="button"
        aria-expanded="false"
        aria-controls="v2-drawer"
        aria-label="Open menu"
        data-v2-drawer-toggle
      >
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <div class="v2-overlay" data-v2-overlay></div>

  <aside class="v2-drawer" id="v2-drawer" aria-label="Mobile preview navigation" data-v2-drawer>
    <div class="v2-drawer__head">
      <strong>Preview navigation</strong>
      <button
        class="v2-drawer__close"
        type="button"
        aria-label="Close menu"
        data-v2-drawer-close
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>

    <nav class="v2-drawer__nav">
      <a href="/v2/">Home</a>
      <a href="/v2/apps/">Apps</a>
      <a href="/v2/resources/">Docs</a>
      <a href="/v2/#rollout">Rollout</a>
    </nav>

    <div class="v2-drawer__downloads">
      <p class="v2-menu__label">Downloads</p>
      <a href="https://apps.apple.com/us/app/mythic-gme-mobile/id6726999147" target="_blank" rel="noopener noreferrer">Apple App Store</a>
      <a href="https://play.google.com/store/apps/details?id=com.jasonholtdigital.mythicgme2e" target="_blank" rel="noopener noreferrer">Google Play</a>
      <a href="https://www.amazon.ca/Jason-Holt-Digital-LLC-Mythic/dp/B0DJBPF9L9" target="_blank" rel="noopener noreferrer">Amazon Appstore</a>
      <a href="https://apps.microsoft.com/detail/9n39b8hj3cdg" target="_blank" rel="noopener noreferrer">Microsoft Store</a>
      <a href="https://jasonholtdigital.itch.io/mythic-gme-digital" target="_blank" rel="noopener noreferrer">itch.io</a>
    </div>
  </aside>
</header>
<script>
  const downloadRoot = document.querySelector<HTMLElement>('[data-v2-download]');
  const downloadToggle = document.querySelector<HTMLButtonElement>('[data-v2-download-toggle]');
  const downloadMenu = document.querySelector<HTMLElement>('[data-v2-download-menu]');
  const drawer = document.querySelector<HTMLElement>('[data-v2-drawer]');
  const overlay = document.querySelector<HTMLElement>('[data-v2-overlay]');
  const drawerToggle = document.querySelector<HTMLButtonElement>('[data-v2-drawer-toggle]');
  const drawerClose = document.querySelector<HTMLButtonElement>('[data-v2-drawer-close]');

  function closeDownloadMenu() {
    if (!downloadToggle || !downloadMenu) return;
    downloadMenu.classList.remove('is-open');
    downloadToggle.setAttribute('aria-expanded', 'false');
  }

  function toggleDownloadMenu() {
    if (!downloadToggle || !downloadMenu) return;
    const open = downloadMenu.classList.toggle('is-open');
    downloadToggle.setAttribute('aria-expanded', String(open));
  }

  function closeDrawer() {
    if (!drawer || !overlay || !drawerToggle) return;
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawerToggle.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('has-v2-drawer-open');
  }

  function openDrawer() {
    if (!drawer || !overlay || !drawerToggle) return;
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawerToggle.setAttribute('aria-expanded', 'true');
    document.body.classList.add('has-v2-drawer-open');
  }

  downloadToggle?.addEventListener('click', () => toggleDownloadMenu());
  drawerToggle?.addEventListener('click', () => openDrawer());
  drawerClose?.addEventListener('click', () => closeDrawer());
  overlay?.addEventListener('click', () => closeDrawer());

  document.addEventListener('click', (event) => {
    if (!downloadRoot || !downloadMenu || !downloadToggle) return;
    if (!downloadRoot.contains(event.target as Node)) closeDownloadMenu();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeDownloadMenu();
      closeDrawer();
    }
  });

  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeDrawer());
  });
</script>
