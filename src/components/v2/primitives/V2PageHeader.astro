---
interface Props {
  badge: string;
  title: string;
  intro: string;
}

const { badge, title, intro } = Astro.props;
---

<section class="v2-page-header" aria-labelledby="v2-page-header-title">
  <div class="v2-wrap">
    <p class="v2-eyebrow">{badge}</p>
    <h1 id="v2-page-header-title" class="v2-page-header__title">{title}</h1>
    <p class="v2-page-header__intro">{intro}</p>
  </div>
</section>
