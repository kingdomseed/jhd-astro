---
// Site-wide search dialog.
// Opens via Cmd/Ctrl+K or "/" key. Uses native <dialog> for modal behavior
// (focus trapping, backdrop, Escape to close — all built in).
// Loads Orama indexes lazily on first open.
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang?: "en" | "pt";
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const resourcesDbName = lang === "pt" ? "resources_pt" : "resources";
const blogDbName = lang === "pt" ? "blog_pt" : "blog";
---
<dialog
  id="search-dialog"
  class="search-overlay__dialog"
  data-search-resources-db={resourcesDbName}
  data-search-blog-db={blogDbName}
  data-search-empty={t("search.empty")}
  data-search-loading={t("search.loading")}
  data-search-no-results={t("search.no_results")}
  data-search-resources={t("search.resources")}
  data-search-blog={t("search.blog")}
  data-search-also-resources={t("search.also_resources")}
  data-search-also-blog={t("search.also_blog")}
>
  <div class="search-overlay__panel">
    <div class="search-overlay__header">
      <i class="fa-slab fa-regular fa-magnifying-glass search-overlay__icon" aria-hidden="true"></i>
      <input
        id="search-input"
        class="search-overlay__input"
        type="search"
        placeholder={t("search.placeholder")}
        autocomplete="off"
      />
      <kbd class="search-overlay__esc">Esc</kbd>
    </div>
    <div class="search-overlay__body" id="search-results">
      <p class="search-overlay__empty">{t("search.empty")}</p>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results')!;
	  const searchCopy = {
	    empty: dialog.dataset.searchEmpty || 'Type to search across resources and blog posts.',
	    loading: dialog.dataset.searchLoading || 'Search is loading...',
	    noResults: dialog.dataset.searchNoResults || 'No results for',
    resources: dialog.dataset.searchResources || 'Resources',
    blog: dialog.dataset.searchBlog || 'Blog',
	    alsoResources: dialog.dataset.searchAlsoResources || 'Also in Resources',
	    alsoBlog: dialog.dataset.searchAlsoBlog || 'Also in Blog',
	  };
	  const searchDbNames = {
	    resources: dialog.dataset.searchResourcesDb || 'resources',
	    blog: dialog.dataset.searchBlogDb || 'blog',
	  };

  // ── Open / Close ──────────────────────────────────────────────────────
  function openSearch() {
    dialog.showModal();
    input.value = '';
    clearResults();
    showEmpty(searchCopy.empty);
    requestAnimationFrame(() => input.focus());
    ensureDBs();
  }

  function closeSearch() {
    dialog.close();
  }

  // Close on backdrop click (click on <dialog> itself, not the panel)
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) closeSearch();
  });

  // Global keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // Cmd/Ctrl+K
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      dialog.open ? closeSearch() : openSearch();
      return;
    }
    // "/" key (only when not in a text field and dialog is closed)
    if (e.key === '/' && !dialog.open) {
      const tag = (document.activeElement?.tagName ?? '').toLowerCase();
      const editable = document.activeElement?.getAttribute('contenteditable');
      if (tag === 'input' || tag === 'textarea' || tag === 'select' || editable) return;
      e.preventDefault();
      openSearch();
    }
  });

  // Listen for custom event (from SearchTrigger if ever re-added)
  document.addEventListener('open-search', () => {
    dialog.open ? closeSearch() : openSearch();
  });

  // ── Orama Search ──────────────────────────────────────────────────────
  import { getOramaDB, search as oramaSearch } from '../../integrations/orama-search-client';

  let resourcesDB: Awaited<ReturnType<typeof getOramaDB>> | null = null;
  let blogDB: Awaited<ReturnType<typeof getOramaDB>> | null = null;
  let debounceTimer: ReturnType<typeof setTimeout>;

	  async function ensureDBs() {
	    if (resourcesDB && blogDB) return;
	    try {
	      if (!resourcesDB) resourcesDB = await getOramaDB(searchDbNames.resources);
	      if (!blogDB) blogDB = await getOramaDB(searchDbNames.blog);
	    } catch (err) {
	      console.error('Failed to load search indexes:', err);
	    }
  }

  function clearResults() {
    resultsContainer.textContent = '';
  }

  function showEmpty(message: string) {
    clearResults();
    const p = document.createElement('p');
    p.className = 'search-overlay__empty';
    p.textContent = message;
    resultsContainer.appendChild(p);
  }

  function highlightTerm(text: string, term: string): DocumentFragment {
    const frag = document.createDocumentFragment();
    if (!term.trim()) {
      frag.appendChild(document.createTextNode(text));
      return frag;
    }
    const escaped = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const regex = new RegExp(`(${escaped})`, 'gi');
    const parts = text.split(regex);
    for (const part of parts) {
      if (part.toLowerCase() === term.toLowerCase()) {
        const mark = document.createElement('mark');
        mark.textContent = part;
        frag.appendChild(mark);
      } else {
        frag.appendChild(document.createTextNode(part));
      }
    }
    return frag;
  }

  function truncateExcerpt(text: string, maxLen = 160): string {
    if (text.length <= maxLen) return text;
    return text.slice(0, maxLen).replace(/\s\S*$/, '') + '\u2026';
  }

  interface SearchHit {
    id: string;
    score: number;
    document: Record<string, unknown>;
  }

  function renderResultLink(hit: SearchHit, term: string): HTMLAnchorElement {
    const doc = hit.document as { path?: string; title?: string; content?: string };
    const link = document.createElement('a');
    link.className = 'search-result';
    link.href = String(doc.path ?? '#');

    const titleSpan = document.createElement('span');
    titleSpan.className = 'search-result__title';
    titleSpan.appendChild(highlightTerm(String(doc.title ?? 'Untitled'), term));
    link.appendChild(titleSpan);

    const excerptSpan = document.createElement('span');
    excerptSpan.className = 'search-result__excerpt';
    const excerpt = truncateExcerpt(String(doc.content ?? ''));
    excerptSpan.appendChild(highlightTerm(excerpt, term));
    link.appendChild(excerptSpan);

    return link;
  }

  function renderGroup(title: string, hits: SearchHit[], term: string): HTMLDivElement | null {
    if (!hits.length) return null;
    const group = document.createElement('div');
    group.className = 'search-group';

    const heading = document.createElement('h3');
    heading.className = 'search-group__title';
    heading.textContent = title;
    group.appendChild(heading);

    for (const hit of hits.slice(0, 5)) {
      group.appendChild(renderResultLink(hit, term));
    }
    return group;
  }

  async function doSearch(term: string) {
    if (!term.trim()) {
      showEmpty(searchCopy.empty);
      return;
    }

    await ensureDBs();
    if (!resourcesDB || !blogDB) {
      showEmpty(searchCopy.loading);
      return;
    }

    const [resResults, blogResults] = await Promise.all([
      oramaSearch(resourcesDB, { term, limit: 5 }),
      oramaSearch(blogDB, { term, limit: 5 }),
    ]);

    const resHits = (resResults?.hits ?? []) as SearchHit[];
    const blogHits = (blogResults?.hits ?? []) as SearchHit[];

    if (!resHits.length && !blogHits.length) {
      showEmpty(`${searchCopy.noResults} \u201c${term}\u201d`);
      return;
    }

    clearResults();

    const onBlog =
      location.pathname.startsWith('/blog/') ||
      location.pathname.startsWith('/pt/blog/');
    const primaryTitle = onBlog ? searchCopy.blog : searchCopy.resources;
    const secondaryTitle = onBlog ? searchCopy.alsoResources : searchCopy.alsoBlog;
    const primaryHits = onBlog ? blogHits : resHits;
    const secondaryHits = onBlog ? resHits : blogHits;

    const primaryGroup = renderGroup(primaryTitle, primaryHits, term);
    const secondaryGroup = renderGroup(secondaryTitle, secondaryHits, term);

    if (primaryGroup) resultsContainer.appendChild(primaryGroup);
    if (secondaryGroup) resultsContainer.appendChild(secondaryGroup);
  }

  // Debounced search on input
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(input.value), 150);
  });

  // Arrow key navigation within results
  dialog.addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
    e.preventDefault();
    const links = Array.from(resultsContainer.querySelectorAll<HTMLAnchorElement>('.search-result'));
    if (!links.length) return;
    const current = document.activeElement as HTMLElement;
    const idx = links.indexOf(current as HTMLAnchorElement);
    let next: number;
    if (e.key === 'ArrowDown') {
      next = idx < 0 ? 0 : Math.min(idx + 1, links.length - 1);
    } else {
      next = idx <= 0 ? -1 : idx - 1;
    }
    if (next < 0) input.focus();
    else links[next].focus();
  });
</script>
