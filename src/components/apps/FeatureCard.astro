---
interface Props {
  heading: string;
  features: string[];
}

const { heading, features } = Astro.props;
---

<div class="feature-card">
  <h3>{heading}</h3>
  <ul class="feature-list">
    {features.map(feature => (
      <li class="feature-item">
        <i class="fa-slab fa-regular fa-check feature-check" aria-hidden="true"></i>
        {feature}
      </li>
    ))}
  </ul>
</div>

<style>
  .feature-card {
    background: var(--color-surface);
    border: var(--border-base);
    padding: 1.5rem;
    box-shadow: 4px 4px 0 0 rgba(0, 0, 0, 0.1);
  }

  .feature-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.1);
    position: relative;
    padding-left: 16px;
  }

  .feature-card h3::before {
    content: '';
    position: absolute;
    width: 4px;
    height: 100%;
    background: var(--color-accent);
    left: 0;
    top: 0;
    border-radius: 0;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    color: var(--color-text);
    font-weight: 500;
  }

  .feature-check {
    color: var(--color-primary);
    font-size: 1.1rem;
    flex-shrink: 0;
    filter: drop-shadow(1px 1px 0 rgba(0, 0, 0, 0.12));
  }

  @media (max-width: 968px) {
    .feature-item {
      padding: 0.6rem 0.8rem;
      font-size: 0.9rem;
    }
  }
</style>
