---
// Popular resources teaser lists frequently accessed documentation
// links.  Each item hints at further content and includes a subtle
// arrow to indicate its interactive nature.  In a full site these
// would link to dedicated guide pages.
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (path: string) => getRelativeLocaleUrl(lang, path);
const resourceLinks = lang === "pt"
  ? {
      gettingStarted: "resources/getting-started-with-the-mythic-apps-pt/",
      customTables: "resources/getting-started-with-custom-tables-pt/",
      tableImport: "resources/importing-and-exporting-custom-tables-pt/",
      diceGuide: "resources/dice-formulas-and-customization-pt/",
    }
  : {
      gettingStarted: "resources/getting-started-with-the-mythic-apps/",
      customTables: "resources/getting-started-with-custom-tables/",
      tableImport: "resources/importing-and-exporting-custom-tables/",
      diceGuide: "resources/dice-formulas-and-customization/",
    };
---

<section
  class="section-block section-block--plain"
  id="resources"
  aria-labelledby="resources-title"
>
  <div class="container section">
    <header class="section-head" aria-hidden="true">
      <span class="accent-line" aria-hidden="true"></span>
      <span class="badge-text">{t("resources.badge")}</span>
    </header>
    <h2 id="resources-title" class="section-title">{t("resources.title")}</h2>
    <ul class="links">
      <li>
        <a href={l(resourceLinks.gettingStarted)}>
          <span class="link-left">
            <i class="fa-slab fa-regular fa-book-open" aria-hidden="true"></i>
            <span>{t("resources.link1")}</span>
          </span>
          <i
            class="fa-slab fa-regular fa-arrow-right link-arrow"
            aria-hidden="true"></i>
        </a>
      </li>
      <li>
        <a href={l(resourceLinks.customTables)}>
          <span class="link-left">
            <i class="fa-slab fa-regular fa-newspaper" aria-hidden="true"></i>
            <span>{t("resources.link2")}</span>
          </span>
          <i
            class="fa-slab fa-regular fa-arrow-right link-arrow"
            aria-hidden="true"></i>
        </a>
      </li>
      <li>
        <a href={l(resourceLinks.tableImport)}>
          <span class="link-left">
            <i class="fa-slab fa-regular fa-arrows-rotate" aria-hidden="true"></i>
            <span>{t("resources.link3")}</span>
          </span>
          <i
            class="fa-slab fa-regular fa-arrow-right link-arrow"
            aria-hidden="true"></i>
        </a>
      </li>
      <li>
        <a href={l(resourceLinks.diceGuide)}>
          <span class="link-left">
            <i class="fa-slab fa-regular fa-percent" aria-hidden="true"></i>
            <span>{t("resources.link4")}</span>
          </span>
          <i
            class="fa-slab fa-regular fa-arrow-right link-arrow"
            aria-hidden="true"></i>
        </a>
      </li>
    </ul>
  </div>
</section>
