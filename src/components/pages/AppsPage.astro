---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import AppSection from '../../components/apps/AppSection.astro';
import m1 from "../../assets/mobile/mobile-1.png";
import m2 from "../../assets/mobile/mobile-2.png";
import m3 from "../../assets/mobile/mobile-3.png";
import m4 from "../../assets/mobile/mobile-4.png";
import m5 from "../../assets/mobile/mobile-5.png";
import m6 from "../../assets/mobile/mobile-6.png";
import m7 from "../../assets/mobile/mobile-7.png";
import d1 from "../../assets/desktop/desktop-1.png";
import d2 from "../../assets/desktop/desktop-2.png";
import d3 from "../../assets/desktop/desktop-3.png";
import d4 from "../../assets/desktop/desktop-4.png";
import d5 from "../../assets/desktop/desktop-5.png";
import d6 from "../../assets/desktop/desktop-6.png";
import d7 from "../../assets/desktop/desktop-7.png";

interface Props {
  lang: 'en' | 'pt';
}

const { lang } = Astro.props;
const isPt = lang === 'pt';

// App data
const mobileApp = {
  title: "Mythic GME Mobile",
  whoItsFor: isPt
    ? "Jogadores solo que querem menos consulta e mais história onde quer que joguem."
    : "Solo role-players who want less lookup and more story wherever they play.",
  features: isPt
    ? [
        "Responda perguntas ao Destino com a Tabela de Destino ou uma Verificação de Destino simplificada",
        "Escreva sua pergunta ao Destino primeiro, depois role",
        "Personagens, Tramas, Características e Cenas",
        "Diário de Aventura com Markdown e corretor ortográfico",
        "Crie, importe, vincule e exporte Tabelas Personalizadas",
        "Salve as fórmulas de dados que você mais usa",
        "Use modos para leitor de tela, daltonismo e uso com a mão esquerda",
      ]
    : [
        "Answer Fate Questions with the Fate Chart or a streamlined Fate Check",
        "Write your Fate Question first, then roll",
        "Track Characters, Threads, Features, and Scenes",
        "Keep an Adventure Log with markdown and spell check",
        "Create, import, link, and export Custom Tables",
        "Save the dice formulas you use most",
        "Use screen reader, color-blind, and left-hand modes",
      ],
  officialContent: isPt
    ? [
        "Comece com as 50 tabelas principais do Mythic GME 2e: 48 Tabelas de Significado e 2 tabelas de Foco de Evento",
        "Expanda para mais de 160 tabelas com Recursos Expandidos, incluindo Variations e Mythic Magazine 1-61",
        "Use tabelas de Foco de Evento para Eventos Aleatórios e Aventuras Preparadas",
        "Novo conteúdo oficial adicionado com grandes lançamentos",
      ]
    : [
        "Start with the 50 core Mythic GME 2e tables: 48 Meaning Tables and 2 Event Focus tables",
        "Expand to 160+ tables with Expanded Features, including Variations and Mythic Magazine issues 1-61",
        "Use Random Event and Prepared Adventure Event Focus tables",
        "New official content comes with major releases",
      ],
  iapInfo: isPt
    ? "Desbloqueios pagos são permanentes, não assinaturas. Tudo o que você desbloquear continua desbloqueado, incluindo novos Recursos Expandidos adicionados nos 12 meses seguintes à compra."
    : "Paid unlocks are permanent, not subscriptions. Anything you unlock stays unlocked, including new paid features added within 12 months of purchase.",
  storeLinks: [
    {
      name: "Apple App Store",
      url: "https://apps.apple.com/us/app/mythic-gme-mobile/id6726999147",
      icon: "fa-brands fa-apple",
    },
    {
      name: "Google Play",
      url: "https://play.google.com/store/apps/details?id=com.jasonholtdigital.mythicgme2e",
      icon: "fa-brands fa-google-play",
    },
    {
      name: "Amazon Appstore",
      url: "https://www.amazon.ca/Jason-Holt-Digital-LLC-Mythic/dp/B0DJBPF9L9",
      icon: "fa-brands fa-amazon",
    },
  ],
};

const desktopApp = {
  title: "Mythic GME Digital",
  whoItsFor: isPt
    ? "Jogadores de Windows, macOS e Linux que querem mais espaço para sessões Mythic mais longas."
    : "Windows, macOS, and Linux players who want more room for longer Mythic sessions.",
  features: isPt
    ? [
        "Use todos os recursos e sistemas do Mythic GME Mobile no desktop",
        "Organize Painéis para combinar com o seu jeito de jogar",
        "Desfaça muitas ações com Cmd/Ctrl+Z",
        "Pesquise na Central de Ajuda do app quando precisar de orientação",
        "Mantenha várias ferramentas visíveis durante sessões mais longas",
        "Receba tudo incluído desde o início, sem assinaturas",
      ]
    : [
        "Use all Mythic GME Mobile features and systems on desktop",
        "Arrange Panels to fit the way you play",
        "Undo many actions with Cmd/Ctrl+Z",
        "Search the in-app Help Center when you need guidance",
        "Keep multiple tools visible during extended sessions",
        "Get everything included up front, with no subscriptions",
      ],
  officialContent: isPt
    ? [
        "Conteúdo oficial Mythic para jogar no desktop",
        "Tabelas e recursos desbloqueados desde o início",
        "Sem assinaturas",
      ]
    : [
        "Official Mythic content for desktop play",
        "Tables and features unlocked up front",
        "No subscriptions",
      ],
  disclaimer: isPt
    ? "Observação: a versão da Mac App Store é um pacote mobile + desktop e usa desbloqueios pagos para conteúdo e recursos adicionais."
    : "Note: the Mac App Store version is a mobile + desktop bundle and uses paid unlocks for additional content and features.",
  storeLinks: [
    {
      name: isPt ? "itch.io (Sem DRM)" : "itch.io (DRM\u2011free)",
      url: "https://jasonholtdigital.itch.io/mythic-gme-digital",
      icon: "fa-brands fa-itch-io",
    },
    {
      name: "Microsoft Store",
      url: "https://apps.microsoft.com/detail/9n39b8hj3cdg",
      icon: "fa-brands fa-windows",
    },
    {
      name: "Steam",
      url: "#",
      icon: "fa-brands fa-steam",
      available: false,
    },
  ],
};

---
<BaseLayout
  title={isPt
    ? "Apps Mythic GME 2e — Mobile e Desktop | Jason Holt Digital"
    : "Apps — Mythic GME 2e Companions | Jason Holt Digital"}
  description={isPt
    ? "Compare os apps oficiais Mythic GME 2e para mobile e desktop, veja o que cada versão inclui e baixe na sua plataforma."
    : "Compare the official Mythic GME 2e apps for mobile and desktop, see what each version includes, and download on your platform."}
  canonicalPath={isPt ? "/pt/apps/" : "/apps/"}
  lang={lang}
  alternatePath={isPt ? "/apps/" : "/pt/apps/"}
  ogTitle={isPt
    ? "Apps Mythic GME 2e — Mobile e Desktop | Jason Holt Digital"
    : "Mythic GME 2e Apps — Mobile & Desktop | Jason Holt Digital"}
  ogDescription={isPt
    ? "Apps oficiais Mythic GME 2e para mobile e desktop, feitos para manter suas ferramentas por perto enquanto você joga."
    : "Official Mythic GME 2e apps for mobile and desktop, built to keep your tools close while you play."}
>
  <PageHeader
    title={isPt ? "Apps Mythic GME" : "Mythic GME Apps"}
    subtitle={isPt ? "Mobile e Desktop, com você onde quer que jogue." : "Mobile & Desktop, with you wherever you play."}
    description={isPt
      ? "Apps oficiais Mythic GME 2e para manter as ferramentas de jogo sempre à mão."
      : "Official Mythic GME 2e apps for keeping the tools of play close at hand."}
    accent="Apps"
    visualElement="grid"
  />

  <!-- Mobile App Section (Left-aligned content) -->
  <AppSection
    title={mobileApp.title}
    whoItsFor={mobileApp.whoItsFor}
    features={mobileApp.features}
    officialContent={mobileApp.officialContent}
    iapInfo={mobileApp.iapInfo}
    storeLinks={mobileApp.storeLinks}
    images={[m1, m2, m3, m4, m5, m6, m7]}
	    imageAlt={isPt ? "Capturas de tela do Mythic GME Mobile" : "Mythic GME Mobile screenshots"}
	    reverse={false}
	    lang={lang}
	  />

  <!-- Adventure Crafter Divider Section -->
  <section
    class="adventure-crafter-divider"
    style="border-top: 4px solid var(--color-border); border-bottom: 4px solid var(--color-border); padding: 3rem 0;"
  >
    <div class="container">
      <header
        class="section-head"
        style="justify-content: center; margin-bottom: 1.5rem;"
        aria-hidden="true"
      >
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">{isPt ? "Em Breve" : "Coming Soon"}</span>
      </header>
      <h2
        class="section-title"
        style="text-align: center; margin-bottom: 1rem;"
      >
        Adventure Crafter
      </h2>
      <p
        class="lead-accent"
        style="text-align: center; margin-bottom: 0;"
      >
        {isPt
          ? "Um futuro app companheiro para criar aventuras com prompts guiados, ganchos e reviravoltas."
          : "A future companion app for creating adventures with guided prompts, hooks, and twists."}
      </p>
    </div>
  </section>

  <!-- Desktop App Section (Left-aligned content) -->
  <AppSection
    title={desktopApp.title}
    whoItsFor={desktopApp.whoItsFor}
    features={desktopApp.features}
    officialContent={desktopApp.officialContent}
    disclaimer={desktopApp.disclaimer}
    storeLinks={desktopApp.storeLinks}
    images={[d1, d2, d3, d4, d5, d6, d7]}
	    imageAlt={isPt ? "Capturas de tela do Mythic GME Digital" : "Mythic GME Desktop screenshots"}
	    reverse={true}
	    lang={lang}
	  />

  <!-- Buy the Books Section -->
  <section class="books-section">
    <div class="container">
      <header
        class="section-head"
        style="justify-content: center; margin-bottom: 2rem;"
        aria-hidden="true"
      >
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">{isPt ? "Livros oficiais" : "Source Books"}</span>
      </header>
      <h2
        class="section-title"
        style="text-align: center; margin-bottom: 1rem;"
      >
        {isPt ? "Adquira os Livros Originais" : "Get the Original Books"}
      </h2>
      <p
        class="lead-accent"
        style="text-align: center; margin-bottom: 2rem;"
      >
        {isPt
          ? "Os apps são companheiros dos livros oficiais de Mythic, escritos por Tana Pigeon."
          : "The apps are companions to the official Mythic books by Tana Pigeon."}
      </p>
      <div class="books-grid">
        <div class="book-card">
          <h3>Mythic GME 2e</h3>
          <p>{isPt ? "O livro-base de Mythic GME 2e para jogo solo e sem mestre." : "The core Mythic GME 2e book for solo and GM-less play."}</p>
          <a
            href="https://www.drivethrurpg.com/product/422929/Mythic-Game-Master-Emulator-Second-Edition"
            target="_blank"
            rel="noopener"
            class="btn btn--shadow-primary"
          >
            <i class="fa-slab fa-regular fa-book" aria-hidden="true"></i>
            {isPt ? "Comprar no DriveThruRPG" : "Buy on DriveThruRPG"}
          </a>
        </div>
        <div class="book-card">
          <h3>Adventure Crafter</h3>
          <p>{isPt ? "Um livro Mythic para criar aventuras com prompts, pontos de virada e reviravoltas." : "A Mythic book for creating adventures with prompts, turning points, and twists."}</p>
          <a
            href="https://www.drivethrurpg.com/product/261479/The-Adventure-Crafter"
            target="_blank"
            rel="noopener"
            class="btn btn--shadow-accent"
          >
            <i class="fa-slab fa-regular fa-book" aria-hidden="true"></i>
            {isPt ? "Comprar no DriveThruRPG" : "Buy on DriveThruRPG"}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Info Section -->
  <section class="app-info-section">
    <div class="container">
      <div class="info-grid">
        <div class="info-card">
          <h3>
            <i class="fa-slab fa-regular fa-shield" aria-hidden="true"></i>
            {isPt ? "Privacidade e Permissões" : "Privacy & Permissions"}
          </h3>
          <p>
            {isPt ? (
              <>Ambos os apps foram criados com coleta mínima de dados. Leia a <a href="/pt/privacy">Política de Privacidade</a> para detalhes.</>
            ) : (
              <>Both apps are built with minimal data collection. Read the <a href="/privacy">Privacy Policy</a> for details.</>
            )}
          </p>
        </div>

        <div class="info-card">
          <h3>
            <i class="fa-slab fa-regular fa-clock" aria-hidden="true"></i>
            {isPt ? "Atualizações e Roteiro" : "Updates & Roadmap"}
          </h3>
          <p>
            {isPt ? (
              <>Leia as notas de lançamento no <a href="/pt/blog">Blog</a> e acompanhe as <a href="http://feedback.jasonholtdigital.com/board" target="_blank" rel="noopener">Solicitações de Recursos</a> para ver o que está sendo considerado ou planejado.</>
            ) : (
              <>Read release notes on the <a href="/blog">Blog</a>, and follow <a href="http://feedback.jasonholtdigital.com/board" target="_blank" rel="noopener">Feature Requests</a> to see what is being considered or planned.</>
            )}
          </p>
        </div>

        <div class="info-card">
          <h3>
            <i class="fa-slab fa-regular fa-circle-question" aria-hidden="true"></i>
            {isPt ? "Suporte e Comunidade" : "Support & Community"}
          </h3>
          <p>
            {isPt ? (
              <>Encontre ajuda no <a href="/pt/support">Suporte</a>, entre no <a href="https://discord.gg/PEDHrhzcnk" target="_blank" rel="noopener">Discord</a> ou envie feedback pelo quadro de recursos.</>
            ) : (
              <>Get help through <a href="/support">Support</a>, join the <a href="https://discord.gg/PEDHrhzcnk" target="_blank" rel="noopener">Discord</a>, or send feedback through the feature board.</>
            )}
          </p>
        </div>

        <div class="info-card">
          <h3>
            <i class="fa-slab fa-regular fa-users" aria-hidden="true"></i>
            {isPt ? "Guiado pelo Feedback" : "Community-Driven"}
          </h3>
          <p>
            {isPt
              ? "O feedback dos jogadores ajuda a orientar os apps, de pequenos ajustes de uso a decisões maiores de planejamento."
              : "Player feedback helps guide the direction of the apps, from small usability improvements to larger planning decisions."}
          </p>
        </div>
      </div>

      <div class="last-updated">
        <small>{isPt ? "Última atualização: 27 de maio de 2026" : "Last updated: May 27, 2026"}</small>
      </div>
    </div>
  </section>

  <section class="section" id="open-source" aria-labelledby="oss-title">
    <div class="container">
      <header class="section-head" aria-hidden="true">
        <span class="accent-line" aria-hidden="true"></span>
        <span class="badge-text">Open Source</span>
      </header>
      <h2 id="oss-title" class="section-title">{isPt ? "Construído com open source" : "Open source tools behind the apps"}</h2>
      <p style="max-width: 640px; margin: 0 auto 1.5rem; text-align: center;">{isPt
        ? "Parte da infraestrutura dos apps Mythic é open source. Confira ou contribua no GitHub."
        : "Some of the code behind the Mythic apps is open source for developers who want to inspect it or contribute."}</p>
      <div class="cards benefits-grid" style="max-width: 640px; margin: 0 auto;">
        <article class="card">
          <div class="card-icon" aria-hidden="true"><i class="fa-brands fa-github"></i></div>
          <h3>icloud_storage_plus</h3>
          <p>{isPt
            ? "Plugin Flutter para armazenamento de documentos no iCloud com acesso coordenado a arquivos."
            : "A Flutter plugin for iCloud document storage and coordinated file access."}</p>
          <a href="https://github.com/kingdomseed/icloud_storage_plus" target="_blank" rel="noopener noreferrer">{isPt ? "Ver no GitHub" : "View on GitHub"} &rarr;</a>
        </article>
        <article class="card">
          <div class="card-icon" aria-hidden="true"><i class="fa-brands fa-github"></i></div>
          <h3>mythic_dice_parser</h3>
          <p>{isPt
            ? "Biblioteca Dart para análise de notação de dados — alimenta o rolador de dados do app."
            : "A Dart library for parsing dice notation used by the app's dice roller."}</p>
          <a href="https://github.com/kingdomseed/mythic-dice-parser" target="_blank" rel="noopener noreferrer">{isPt ? "Ver no GitHub" : "View on GitHub"} &rarr;</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
